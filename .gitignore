# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# runtime data (kept ignored except production Twitter signal snapshots)
/.data/*
!/.data/
!/.data/twitter-repo-signals.jsonl
!/.data/twitter-scans.jsonl
!/.data/twitter-ingestion-audit.jsonl

# local Claude Code workspace (agent prompts, skills, settings)
/.claude/

# operator-local agent + audit + codex tooling (not for commit)
/.agents/
/.audit/
/.codex/
/.claude-flow/
/.swarm/
/.mcp.json
/AGENTS.md
/ruvector.db

# mcp workspace build artifacts + installed deps
/mcp/node_modules/
/mcp/dist/
.next-dev-*.log
.next-dev-debug.*.log


# local dev logs (next start -p <port> redirects)
.next-start-*.log
.next-start-*.out.log
.next-start-*.err.log

# dogfood script output
dogfood-output/

# playwright-mcp local capture / trace output
.playwright-mcp/

# playwright e2e — install reports, traces, screenshots
/playwright-report/
/test-results/
/blob-report/
/.cache/playwright/

# local build / typecheck logs
build_*.log
build-*.log
typecheck_*.log
dev_server*.log

# scratch probe directories from local debug sessions
tmp_probe/
.tmp/

# personal operator rules (per CLAUDE.md — not for commit)
CLAUDE.local.md

# embedded clones (not submodules)
awesome-codex-skills/

# agent scratch directories — never commit, even by accident
.audit/
.claude-flow/
.hive-mind/
.tmp-*.log
