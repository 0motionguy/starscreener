#!/usr/bin/env sh
# Pre-commit hook: typecheck + full lint:guards suite before every commit.
#
# `lint:guards` runs the 7-check suite covering:
#   - lint:tokens — no legacy V2/V3 token usage
#   - lint:err-message — no err.message echoes in route handlers
#   - lint:zod-routes — every mutating route validates body with Zod (P0)
#   - lint:runtime — every API route declares runtime explicitly
#   - lint:err-envelope — every route uses {ok:false,error,code?} shape
#   - lint:v3-budget — V3 token usage stays within baseline (regression check)
#   - lint:bypass — no pool-bypass patterns leak into client paths
#
# Full `npm test` is intentionally NOT run here (8+ sub-suites, ~30s).
# CI gates the full test run; pre-commit catches the most common breaks.
#
# Total cost: ~10s (4s tsc + ~5s guards). Measured 2026-05-02.
#
# To bypass for an emergency commit:  git commit --no-verify
# (use sparingly — CI catches the same things, just slower)

cd "$(dirname "$0")/.."
npx --no-install tsc --noEmit && npm run lint:guards --silent
