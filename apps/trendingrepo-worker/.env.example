# =====================================================================
# trendingrepo-worker env template - copy to .env.local and fill in.
# Never commit .env.local. Service-role tokens stay on the worker only.
# =====================================================================

# --- Supabase (cold tier: normalized rows, daily metrics, MV) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE=

# --- Redis (hot tier: leaderboard JSON for the frontend) ---
# Pick exactly ONE backend - data-store auto-detects on URL scheme.
# Railway native (preferred for production):
REDIS_URL=
# OR Upstash REST (preferred for Vercel-only deploys):
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Source auth ---
GH_PAT=                         # 5K req/hr; required in production
HF_TOKEN=                       # optional; raises HF rate limits
PRODUCTHUNT_TOKEN=              # ProductHunt GraphQL bearer
BLUESKY_HANDLE=                 # AT Protocol login
BLUESKY_APP_PASSWORD=           # AT Protocol app password (NOT account password)

# --- Crawl-only sources ---
FIRECRAWL_API_KEY=              # already provisioned for STARSCREENER

# --- MCP source APIs (Trending MCP leaderboard) ---
GLAMA_API_KEY=                  # https://glama.ai - free tier, security grades
PULSEMCP_API_KEY=               # https://pulsemcp.com - X-API-Key header
PULSEMCP_TENANT_ID=             # paired with PULSEMCP_API_KEY (X-Tenant-ID)
SMITHERY_API_KEY=               # https://smithery.ai - bearer token

# --- Observability ---
# Sentry org agnt-pf (EU), team agnt, project trendingrepo-worker.
# DSN format: https://<key>@o<orgid>.ingest.de.sentry.io/<projectid>
SENTRY_DSN=

# --- Runtime ---
NODE_ENV=development
PORT=8080
LOG_LEVEL=info                  # trace|debug|info|warn|error|fatal
DATA_STORE_DISABLE=             # "1" to bypass Redis writes entirely (debug)
