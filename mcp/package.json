{
  "name": "starscreener-mcp",
  "version": "0.1.0",
  "description": "MCP server exposing TrendingRepo open-source trend intelligence to AI agents via stdio.",
  "type": "module",
  "bin": {
    "starscreener-mcp": "dist/server.js"
  },
  "main": "./dist/server.js",
  "files": [
    "dist/**",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "starscreener",
    "trendingrepo",
    "github",
    "trending",
    "open-source-intelligence",
    "ai-agents",
    "claude"
  ],
  "license": "MIT",
  "author": "Mirko Basil Dolger",
  "homepage": "https://github.com/0motionguy/starscreener#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0motionguy/starscreener.git",
    "directory": "mcp"
  },
  "bugs": {
    "url": "https://github.com/0motionguy/starscreener/issues"
  },
  "scripts": {
    "build": "tsc -p .",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p .",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
