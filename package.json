{
  "name": "trendingrepo-app",
  "version": "0.1.0",
  "private": true,
  "description": "TrendingRepo — the trend map for open source. Live GitHub, Reddit, Hacker News, ProductHunt, Bluesky, and dev.to signals, a bubble map, cross-signal breakouts, CLI, and MCP so every agent and terminal sees what's heating up.",
  "homepage": "https://trendingrepo.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/0motionguy/starscreener.git"
  },
  "bugs": {
    "url": "https://github.com/0motionguy/starscreener/issues"
  },
  "license": "MIT",
  "engines": {
    "node": "22.x"
  },
  "keywords": [
    "github-trending",
    "ai-agents",
    "mcp",
    "model-context-protocol",
    "portal-v0.1",
    "nextjs",
    "dexscreener",
    "terminal-ui",
    "open-source-discovery",
    "momentum-scoring"
  ],
  "bin": {
    "ss": "./bin/ss.mjs"
  },
  "scripts": {
    "cli:dev": "node bin/ss.mjs",
    "prepare": "husky",
    "dev": "next dev --turbopack -p 3023",
    "build": "next build",
    "postbuild": "node scripts/sanitize-next-traces.mjs",
    "analyze": "cross-env ANALYZE=true next build",
    "start": "next start -p 3023",
    "lint": "eslint",
    "lint:tokens": "node scripts/check-no-legacy-tokens.mjs",
    "lint:err-message": "node scripts/check-no-err-message-echoes.mjs",
    "lint:zod-routes": "node scripts/check-zod-on-mutating-routes.mjs",
    "lint:runtime": "node scripts/check-route-runtime.mjs",
    "lint:err-envelope": "node scripts/check-error-envelope.mjs",
    "lint:v3-budget": "node scripts/check-v3-token-budget.mjs",
    "lint:v3-budget:snapshot": "node scripts/check-v3-token-budget.mjs --snapshot",
    "lint:guards": "npm run lint:tokens && npm run lint:err-message && npm run lint:zod-routes && npm run lint:runtime && npm run lint:err-envelope && npm run lint:v3-budget",
    "audit:status": "node scripts/audit-status.mjs",
    "update:badges": "node scripts/update-readme-badges.mjs",
    "test": "npm run test:scraper-shared && npm run test:reddit && npm run test:hn && npm run test:bsky && npm run test:ph && npm run test:devto && npm run test:npm && npm run test:funding && npm run test:twitter-collector && tsx --test src/lib/__tests__/*.test.ts src/lib/pipeline/__tests__/*.test.ts src/lib/twitter/__tests__/*.test.ts src/tools/__tests__/*.test.ts src/portal/__tests__/*.test.ts",
    "test:scraper-shared": "node --test scripts/__tests__/fetch-json.test.mjs scripts/__tests__/github-repo-links.test.mjs scripts/__tests__/reddit-shared.test.mjs scripts/__tests__/tracked-repos.test.mjs scripts/__tests__/source-watchers.test.mjs scripts/__tests__/trustmrr-sync-mode.test.mjs",
    "test:reddit": "node --test scripts/__tests__/classify-post.test.mjs scripts/__tests__/scrape-reddit.test.mjs",
    "test:hn": "node --test scripts/__tests__/scrape-hackernews.test.mjs",
    "test:bsky": "node --test scripts/__tests__/scrape-bluesky.test.mjs",
    "test:ph": "node --test scripts/__tests__/scrape-producthunt.test.mjs",
    "test:devto": "node --test scripts/__tests__/scrape-devto.test.mjs",
    "test:npm": "node --test scripts/__tests__/scrape-npm.test.mjs",
    "test:funding": "node --test scripts/__tests__/scrape-funding.test.mjs",
    "test:twitter-collector": "tsx --test scripts/__tests__/twitter-collector.test.ts",
    "test:tools": "tsx --test src/tools/__tests__/*.test.ts",
    "test:portal": "tsx --test src/portal/__tests__/*.test.ts",
    "test:hooks": "vitest run --config vitest.config.ts",
    "test:hooks:watch": "vitest --config vitest.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "verify:data-store": "node scripts/verify-data-store.mjs",
    "scrape": "node scripts/scrape-trending.mjs",
    "scrape:reddit": "node scripts/scrape-reddit.mjs",
    "scrape:hn": "node scripts/scrape-hackernews.mjs",
    "scrape:bsky": "node scripts/scrape-bluesky.mjs",
    "scrape:ph": "node scripts/scrape-producthunt.mjs",
    "scrape:devto": "node scripts/scrape-devto.mjs",
    "scrape:lobsters": "node scripts/scrape-lobsters.mjs",
    "scrape:arxiv": "node scripts/scrape-arxiv.mjs",
    "scrape:huggingface": "node scripts/scrape-huggingface.mjs",
    "ingest:arxiv-cited": "node scripts/ingest-arxiv-cited-repos.mjs",
    "scrape:npm": "node scripts/scrape-npm.mjs",
    "collect:twitter": "tsx scripts/collect-twitter-signals.ts",
    "collect:twitter:api": "tsx scripts/collect-twitter-signals.ts --mode api",
    "scrape:funding": "node scripts/scrape-funding-news.mjs --enrich",
    "collect:twitter:dry": "tsx scripts/collect-twitter-signals.ts --dry-run --output .tmp/twitter-collector-preview.json",
    "purge:twitter:synthetic": "tsx scripts/purge-twitter-synthetic-data.ts",
    "audit:freshness": "tsx scripts/audit-source-freshness.ts",
    "enrich:profiles": "node scripts/enrich-repo-profiles.mjs",
    "enrich:profiles:top": "node scripts/enrich-repo-profiles.mjs --mode top",
    "enrich:profiles:catchup": "node scripts/enrich-repo-profiles.mjs --mode catchup",
    "enrich:profiles:incremental": "node scripts/enrich-repo-profiles.mjs --mode incremental",
    "compute:reddit-baselines": "node scripts/compute-reddit-baselines.mjs",
    "discover:recent": "node scripts/discover-recent-repos.mjs",
    "fetch:metadata": "node scripts/fetch-repo-metadata.mjs",
    "compute-deltas": "node scripts/compute-deltas.mjs",
    "recompute": "curl -X POST http://localhost:3023/api/pipeline/recompute",
    "ingest:sample": "curl -X POST http://localhost:3023/api/pipeline/ingest -H 'Content-Type: application/json' -d '{\"fullNames\":[\"vercel/next.js\",\"ollama/ollama\",\"anthropics/claude-code\"]}'",
    "reset:data": "node scripts/reset-data.mjs",
    "backfill:history": "curl -X POST -H \"Authorization: Bearer $CRON_SECRET\" -H \"Content-Type: application/json\" -d",
    "mcp:build": "cd mcp && npm install && npm run build",
    "mcp:dev": "cd mcp && npm run dev",
    "mcp:inspect": "npx @modelcontextprotocol/inspector node mcp/dist/server.js",
    "portal:conformance": "node scripts/portal-conformance.mjs"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.50.0",
    "@upstash/redis": "^1.37.0",
    "framer-motion": "^12.38.0",
    "ioredis": "^5.10.1",
    "linkedom": "^0.18.12",
    "lucide-react": "^1.8.0",
    "next": "15.5.15",
    "next-themes": "^0.4.6",
    "p-limit": "^7.3.0",
    "posthog-js": "^1.372.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "recharts": "^3.8.1",
    "resend": "^6.12.0",
    "sonner": "^2.0.7",
    "stripe": "^17.7.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "happy-dom": "^15.11.7",
    "husky": "^9.1.7",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
