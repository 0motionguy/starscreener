{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/trendingrepo-worker/Dockerfile"
  },
  "deploy": {
    "startCommand": "node --enable-source-maps --max-old-space-size=512 dist/index.js --cron",
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
