{
  "crons": [
    { "path": "/api/cron/ingest?tier=hot", "schedule": "0 * * * *" },
    { "path": "/api/cron/ingest?tier=warm", "schedule": "0 */6 * * *" },
    { "path": "/api/cron/ingest?tier=cold", "schedule": "0 0 * * *" },
    { "path": "/api/cron/backfill-top?n=20", "schedule": "30 2 * * *" }
  ],
  "functions": {
    "src/app/api/pipeline/recompute/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/ingest/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/seed/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/backfill-top/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/pipeline/backfill-history/route.ts": {
      "maxDuration": 300
    }
  }
}
